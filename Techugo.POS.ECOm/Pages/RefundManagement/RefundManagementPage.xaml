<UserControl x:Class="Techugo.POS.ECOm.Pages.RefundManagementPage"
   xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:conv="clr-namespace:Techugo.POS.ECOm.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Techugo.POS.ECOm"
             xmlns:helpers="clr-namespace:Techugo.POS.ECOm.Helper"
Height="Auto" Width="Auto">

    <UserControl.Resources>
        <conv:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter" />
        <conv:StatusToForegroundConverter x:Key="StatusToForegroundConverter" />

        <!-- Reusable card style so all cards are identical in shape/size -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E6E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="8" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search box style -->
        <Style x:Key="SearchBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <!-- Filter pill style (rounded pill with border) -->
        <Style x:Key="FilterPillBorder" TargetType="Border">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="beige"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Products ListView header style -->
        <Style x:Key="GridHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#FCFAFB">
        <StackPanel Margin="32">
            <!-- Back Button -->
            <Border Grid.Column="0" Width="Auto" Height="36" Padding="8,0,12,0" Background="#fff" BorderBrush="#e3e3e3" CornerRadius="8" BorderThickness="1" MouseLeftButtonUp="BackButton_Click"
TouchUp="BackButton_Click" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <svg:SvgViewbox Source="/Assets/Images/back.svg" Width="12" Height="12" VerticalAlignment="Center" Margin="8,0,8,0"/>
                    <TextBlock Text="Back to Dashboard" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Refund Management" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Track and manage customer refunds across all payment modes" FontSize="14" Foreground="#888" Margin="0,4,0,24"/>

            <!-- Search + Filter row -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Style="{StaticResource SearchBoxStyle}" Grid.Column="0">
                    

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- magnifier icon (simple Path) -->
                        <svg:SvgViewbox Source="/Assets/Images/search.svg"  Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>


                        <!-- TextBox with overlay placeholder -->
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="SearchBox"
                 BorderThickness="0"
                 Background="Transparent"
                 FontSize="14"
                 Foreground="#111827"
                 VerticalContentAlignment="Center"
                 helpers:TouchKeyboardHelper.Enable="True"
                 Padding="6,0"
                 TextChanged="SearchBox_TextChanged" />
                            <TextBlock Text="Search by order number"
       IsHitTestVisible="False"
       Foreground="Gray"
       FontSize="14"
       VerticalAlignment="Center"
       Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                        </Grid>
                    </Grid>
                </Border>

                <!-- Payment Mode Filter pill -->
                <Border Grid.Column="1" Style="{StaticResource FilterPillBorder}" Margin="12,0,0,0">
                    


                    <Grid Width="150">
                        <svg:SvgViewbox Width="18" Height="20"
    VerticalAlignment="Center"
    HorizontalAlignment="Left" Source="/Assets/Images/filter.svg" />
                        <!-- Overlay ComboBox -->
                        <ComboBox x:Name="PaymentModeFilterCombo"
          Width="180"
          Background="Transparent"
          BorderThickness="0"
          Padding="6,0"
          VerticalContentAlignment="Center"
          HorizontalContentAlignment="Center"
          Foreground="#111827"
          FontSize="14"
          FocusVisualStyle="{x:Null}"
          materialDesign:TextFieldAssist.UnderlineBrush="Transparent"
              SelectionChanged="PaymentModeFilterCombo_SelectionChanged"
              SelectedIndex="0">
                            <ComboBoxItem Tag="COD" IsSelected="True">COD</ComboBoxItem>
                            <ComboBoxItem Tag="ONLINE">Online</ComboBoxItem>
                            <ComboBoxItem Tag="WALLET">Wallet</ComboBoxItem>
                            <ComboBoxItem Tag="CREDIT_WALLET">Credit Wallet</ComboBoxItem>

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- You can add icons, styling, etc. -->
                                        <TextBlock Text="{Binding BrandName}" FontSize="14" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="Padding" Value="12,4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border x:Name="Bd"
            Background="Transparent"
            Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <!-- Hover -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                                                        <!-- light gray -->
                                                    </Trigger>
                                                    <!-- Selected -->
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#D1D5DB"/>
                                                        <!-- darker gray -->
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </Trigger>
                                                    <!-- Disabled -->
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                                                        <Setter Property="Foreground" Value="#9CA3AF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>


                                </Style>


                            </ComboBox.ItemContainerStyle>

                        </ComboBox>

                    </Grid>

                </Border>
            </Grid>


            <!-- Stats row -->
            <Grid Margin="0,0,0,24" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Total Refunds -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Refunds" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding TotalRefunds}" FontSize="26" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Initiated -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Initiated" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding InitiatedCount}" FontSize="26" FontWeight="SemiBold"  Foreground="#D97706"/>
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="#FEF3C7" CornerRadius="16" Padding="10,6" HorizontalAlignment="Right">
                                <TextBlock Text="Initiated" Foreground="#D97706"  FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Processing -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Processing" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding ProcessingCount}" FontSize="26" FontWeight="SemiBold"  Foreground="Blue "/>
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="#DBEAFE" CornerRadius="16" Padding="10,6" HorizontalAlignment="Right">
                                <TextBlock Text="Processing" Foreground="#1E40AF" FontSize="12"  FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Completed -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Completed" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding CompletedCount}" FontSize="26" FontWeight="SemiBold"  Foreground="green"/>
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="#DCFCE7" CornerRadius="16" Padding="10,6" HorizontalAlignment="Right">
                                <TextBlock Text="Completed" Foreground="#16A34A" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

           
            
            <!-- Refunds Table -->
            <Border Background="White" BorderBrush="#E6E7EB" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                        <svg:SvgViewbox Source="/Assets/Images/orders.svg" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding RefundOrderText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Refunds ListView -->
                    <ListView x:Name="RefundsListView" ItemsSource="{Binding RefundData}" SelectionMode="Single"
BorderThickness="0"
Margin="0"
ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Hidden" local:MouseWheelForwarder.ForwardToParent="True">
                        <!-- row style -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="MinHeight" Value="72"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#0a0a0a"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FAFAFB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.View>
                            <GridView>
                                <!-- Order Number -->
                                <GridViewColumn Header="Order Id" Width="150" DisplayMemberBinding="{Binding OrderNo}" />
                                <GridViewColumn Header="Customer Details" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding MobileNo}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" MaxWidth="300"/>
                                                <TextBlock Text="{Binding ShortAddress}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" MaxWidth="300"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Order Items" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <ItemsControl ItemsSource="{Binding OrderDetails}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Item.ItemName}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" MaxWidth="300"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <!-- Refund Amount -->
                                <GridViewColumn Header="Refund Amount" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Amount, StringFormat=₹{0:F2}}" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Refund Status -->
                                <GridViewColumn Header="Refund Status" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="StatusBadge" CornerRadius="12" Padding="8,4" HorizontalAlignment="Left" Margin="0,4,0,4">
                                                <TextBlock x:Name="StatusText" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Initiated">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#FEF3C7"/>
                                                    <Setter TargetName="StatusText" Property="Text" Value="Initiated"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#D97706"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#DBEAFE"/>
                                                    <Setter TargetName="StatusText" Property="Text" Value="Processing"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#1E40AF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#DCFCE7"/>
                                                    <Setter TargetName="StatusText" Property="Text" Value="Completed"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#16A34A"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Refund Date -->
                                <GridViewColumn Header="Refund Date" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <Binding Path="CreatedAt"
StringFormat="{}{0:yyyy-MM-dd, hh:mm tt}"
TargetNullValue=""
FallbackValue=""/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                

                            </GridView>
                        </ListView.View>

                        <!-- GridView header template/style -->
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource GridHeaderStyle}" />
                        </ListView.Resources>
                        <ListView.Style>
                            <Style TargetType="ListView">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RefundData.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListView">
                                                    <TextBlock Text="No items to display"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Foreground="Gray" FontSize="14"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Style>
                    </ListView>

                    <!-- Pagination Controls -->
                    <Grid Margin="0,16,0,0" x:Name="PaginationSection">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Previous Button -->
                        <Border Grid.Column="0"
                                Background="#F3F4F6"
                                BorderBrush="#E6E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="0">
                            <Button Content="← Previous"
                                    Height="36"
                                    Width="100"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#111827"
                                    IsEnabled="{Binding CanGoToPreviousPage}"
                                    Click="PreviousButton_Click"/>
                        </Border>
                        
                        <!-- Page Info -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PaginationText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"/>
                        
                        <!-- Next Button -->
                        <Border Grid.Column="2"
                                Background="#F3F4F6"
                                BorderBrush="#E6E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="0">
                            <Button Content="Next →"
                                    Height="36"
                                    Width="100"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#111827"
                                    IsEnabled="{Binding CanGoToNextPage}"
                                    Click="NextButton_Click"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>