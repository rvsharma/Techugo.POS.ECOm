<UserControl x:Class="Techugo.POS.ECOm.Pages.RefundManagementPage"
   xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:conv="clr-namespace:Techugo.POS.ECOm.Converters"
Height="Auto" Width="Auto">

    <UserControl.Resources>
        <conv:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter" />
        <conv:StatusToForegroundConverter x:Key="StatusToForegroundConverter" />

        <!-- Reusable card style so all cards are identical in shape/size -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E6E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="8" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search box style -->
        <Style x:Key="SearchBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <!-- Filter pill style (rounded pill with border) -->
        <Style x:Key="FilterPillBorder" TargetType="Border">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="beige"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Products ListView header style -->
        <Style x:Key="GridHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#FCFAFB">
        <StackPanel Margin="32">
            <!-- Back Button -->
            <Border Grid.Column="0" Width="Auto" Height="36" Padding="8,0,12,0" Background="#fff" BorderBrush="#e3e3e3" CornerRadius="8" BorderThickness="1" MouseLeftButtonUp="BackButton_Click"
TouchUp="BackButton_Click" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <svg:SvgViewbox Source="/Assets/Images/back.svg" Width="12" Height="12" VerticalAlignment="Center" Margin="8,0,8,0"/>
                    <TextBlock Text="Back to Dashboard" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Refund Management" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Track and manage customer refunds across all payment modes" FontSize="14" Foreground="#888" Margin="0,4,0,24"/>

            <!-- Search + Filter row -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Style="{StaticResource SearchBoxStyle}" Grid.Column="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- magnifier icon -->
                        <Viewbox Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="16">
                                <Path Data="M15.5,14h-0.79l-0.28-0.27A6.471,6.471,0,1,0,14,15.5l0.27,0.28v0.79L20,21.5,21.5,20,15.5,14z M6.5,11A4.5,4.5,0,1,1,11,15.5,4.5,4.5,0,0,1,6.5,11z"
                        Fill="#9CA3AF" Stretch="Uniform"/>
                            </Canvas>
                        </Viewbox>

                        <!-- TextBox -->
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="SearchBox"
                       BorderThickness="0"
                       Background="Transparent"
                       FontSize="14"
                       Foreground="#111827"
                       VerticalContentAlignment="Center"
                       Padding="6,0"
                       TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Text="Search by customer name, order ID, or phone..."
                         FontSize="14"
                         Foreground="#9CA3AF"
                         Margin="6,0,0,0"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Payment Mode Filter pill -->
                <Border Grid.Column="1" Style="{StaticResource FilterPillBorder}" Margin="12,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="49"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Payment mode icon -->
                        <Viewbox Grid.Column="0" Width="18" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Canvas Width="12" Height="10">
                                <Path Data="M3,3 L13,3 L9,8 L9,13 L7,13 L7,8 Z" Fill="gray" Stretch="Uniform"/>
                            </Canvas>
                        </Viewbox>

                        <!-- Payment Mode ComboBox -->
                        <ComboBox Grid.Column="1"
                      x:Name="PaymentModeFilterCombo"
                      Background="#F3F4F6"
                      BorderThickness="0"
                      Padding="6,0"
                      Width="180"
                      VerticalContentAlignment="Center"
                      HorizontalContentAlignment="Left"
                      Foreground="#111827"
                      SelectionChanged="PaymentModeFilterCombo_SelectionChanged"
                      SelectedIndex="0">
                            <ComboBoxItem Tag="COD" IsSelected="True">COD</ComboBoxItem>
                            <ComboBoxItem Tag="ONLINE">Online</ComboBoxItem>
                            <ComboBoxItem Tag="WALLET">Wallet</ComboBoxItem>
                            <ComboBoxItem Tag="CREDIT_WALLET">Credit Wallet</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </Border>
            </Grid>


            <!-- Stats row -->
            <Grid Margin="0,0,0,24" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Total Refunds -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Refunds" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding TotalRefunds}" FontSize="26" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Initiated -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Initiated" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding InitiatedCount}" FontSize="26" FontWeight="SemiBold"  Foreground="orange"/>
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="LightYellow" CornerRadius="16" Padding="10,6" HorizontalAlignment="Right">
                                <TextBlock Text="Initiated" Foreground="Orange"  FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Processing -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Processing" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding ProcessingCount}" FontSize="26" FontWeight="SemiBold"  Foreground="Blue "/>
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="LightBlue" CornerRadius="16" Padding="10,6" HorizontalAlignment="Right">
                                <TextBlock Text="Processing" Foreground="Blue" FontSize="12"  FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Completed -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Completed" FontSize="14" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding CompletedCount}" FontSize="26" FontWeight="SemiBold"  Foreground="green"/>
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="LightGreen" CornerRadius="16" Padding="10,6" HorizontalAlignment="Right">
                                <TextBlock Text="Completed" Foreground="green" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

           
            
            <!-- Refunds Table -->
            <Border Background="White" BorderBrush="#E6E7EB" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                        <svg:SvgViewbox Source="/Assets/Images/orders.svg" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding RefundOrderText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Refunds ListView -->
                    <ListView x:Name="RefundsListView" ItemsSource="{Binding RefundData}" Margin="0" BorderThickness="0" SelectionMode="Single">
                        <!-- row style -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="MinHeight" Value="72"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#0a0a0a"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FAFAFB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.View>
                            <GridView>
                                <!-- Order Number -->
                                <GridViewColumn Header="Order Id" Width="150" DisplayMemberBinding="{Binding OrderNo}" />
                                <GridViewColumn Header="Customer Details" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding MobileNo}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" MaxWidth="300"/>
                                                <TextBlock Text="{Binding ShortAddress}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" MaxWidth="300"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Order Items" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <ItemsControl ItemsSource="{Binding OrderDetails}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Item.ItemName}" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" MaxWidth="300"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <!-- Refund Amount -->
                                <GridViewColumn Header="Refund Amount" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Amount, StringFormat=₹{0:F2}}" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Refund Status -->
                                <GridViewColumn Header="Refund Status" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="StatusBadge" CornerRadius="12" Padding="8,4" HorizontalAlignment="Left" Margin="0,4,0,4">
                                                <TextBlock x:Name="StatusText" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Initiated">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#FEF3C7"/>
                                                    <Setter TargetName="StatusText" Property="Text" Value="Initiated"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#D97706"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#DBEAFE"/>
                                                    <Setter TargetName="StatusText" Property="Text" Value="Processing"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#1E40AF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#DCFCE7"/>
                                                    <Setter TargetName="StatusText" Property="Text" Value="Completed"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#16A34A"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Refund Date -->
                                <GridViewColumn Header="Refund Date" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <Binding Path="CreatedAt"
StringFormat="{}{0:yyyy-MM-dd, hh:mm tt}"
TargetNullValue=""
FallbackValue=""/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                

                            </GridView>
                        </ListView.View>

                        <!-- GridView header template/style -->
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource GridHeaderStyle}" />
                        </ListView.Resources>
                    </ListView>

                    <!-- Pagination Controls -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Previous Button -->
                        <Border Grid.Column="0"
                                Background="#F3F4F6"
                                BorderBrush="#E6E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="0">
                            <Button Content="← Previous"
                                    Height="36"
                                    Width="100"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#111827"
                                    IsEnabled="{Binding CanGoToPreviousPage}"
                                    Click="PreviousButton_Click"/>
                        </Border>
                        
                        <!-- Page Info -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PaginationText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"/>
                        
                        <!-- Next Button -->
                        <Border Grid.Column="2"
                                Background="#F3F4F6"
                                BorderBrush="#E6E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="0">
                            <Button Content="Next →"
                                    Height="36"
                                    Width="100"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#111827"
                                    IsEnabled="{Binding CanGoToNextPage}"
                                    Click="NextButton_Click"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>